# =============================================================
# PowerBook - logs/.htaccess
# =============================================================
# Defense in Depth: Logfiles enthalten potenziell sensible
# Informationen (IPs, Stacktraces, Form-Submissions). Auch
# falls jemand das Verzeichnis versehentlich auf den Live-
# Server kopiert oder Root-.htaccess nicht greift, ist hier
# alles dicht.
# =============================================================

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
