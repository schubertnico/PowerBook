{
    "name": "schubertnico/powerbook",
    "description": "PowerBook - PHP Guestbook System (modernized for PHP 8.4)",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Axel Habermaier",
            "email": "expandable@powerscripts.org",
            "role": "Original Author"
        },
        {
            "name": "Nico Schubert",
            "role": "PHP 8.4 Migration"
        }
    ],
    "homepage": "https://github.com/schubertnico/PowerBook.git",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "files": [
            "pb_inc/functions.inc.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PowerBook\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=512M",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:coverage": "phpunit --coverage-text",
        "setup-hooks": [
            "@php -r \"copy('hooks/pre-commit', '.git/hooks/pre-commit');\"",
            "@php -r \"chmod('.git/hooks/pre-commit', 0755);\""
        ],
        "phpmd": "phpmd pb_inc text phpmd.xml --suffixes php,inc",
        "check": [
            "@phpstan",
            "@phpmd",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4"
        }
    }
}
