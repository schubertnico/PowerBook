<?xml version="1.0"?>
<ruleset name="PowerBook PHPMD Rules"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>PHPMD Ruleset for PowerBook PHP Guestbook</description>

    <!-- Clean Code Rules -->
    <rule ref="rulesets/cleancode.xml">
        <!-- Allow static access for helper functions -->
        <exclude name="StaticAccess"/>
        <!-- Allow else expressions in legacy code -->
        <exclude name="ElseExpression"/>
        <!-- Allow boolean flags for optional parameters -->
        <exclude name="BooleanArgumentFlag"/>
        <!-- Allow @ operator for file operations where errors are handled -->
        <exclude name="ErrorControlOperator"/>
        <!-- PHP built-in classes don't need imports -->
        <exclude name="MissingImport"/>
    </rule>

    <!-- Code Size Rules -->
    <rule ref="rulesets/codesize.xml">
        <!-- Adjust thresholds for legacy code -->
        <exclude name="TooManyPublicMethods"/>
        <exclude name="ExcessiveClassComplexity"/>
    </rule>

    <!-- Cyclomatic Complexity - adjusted threshold -->
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="15"/>
        </properties>
    </rule>

    <!-- NPath Complexity - adjusted threshold -->
    <rule ref="rulesets/codesize.xml/NPathComplexity">
        <properties>
            <property name="minimum" value="300"/>
        </properties>
    </rule>

    <!-- Method Length -->
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="150"/>
        </properties>
    </rule>

    <!-- Controversial Rules -->
    <rule ref="rulesets/controversial.xml">
        <!-- Allow superglobals in this legacy application -->
        <exclude name="Superglobals"/>
        <!-- Allow camelCase for variables -->
        <exclude name="CamelCaseVariableName"/>
        <exclude name="CamelCaseParameterName"/>
    </rule>

    <!-- Design Rules -->
    <rule ref="rulesets/design.xml">
        <!-- Allow exit in admin context -->
        <exclude name="ExitExpression"/>
        <!-- Allow eval for specific cases -->
        <exclude name="EvalExpression"/>
    </rule>

    <!-- Naming Rules -->
    <rule ref="rulesets/naming.xml">
        <!-- Allow short variable names like $e, $i, $id -->
        <exclude name="ShortVariable"/>
        <!-- Allow long variable names for clarity -->
        <exclude name="LongVariable"/>
        <!-- Allow short method names like e() -->
        <exclude name="ShortMethodName"/>
    </rule>

    <!-- Short variable names - only very short ones -->
    <rule ref="rulesets/naming.xml/ShortVariable">
        <properties>
            <property name="minimum" value="2"/>
            <property name="exceptions" value="e,i,j,k,n,id,ip,to"/>
        </properties>
    </rule>

    <!-- Short method names - allow specific helper functions -->
    <rule ref="rulesets/naming.xml/ShortMethodName">
        <properties>
            <property name="minimum" value="2"/>
            <property name="exceptions" value="e"/>
        </properties>
    </rule>

    <!-- Unused Code Rules -->
    <rule ref="rulesets/unusedcode.xml">
        <!-- Allow unused parameters for interface compatibility -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

</ruleset>
